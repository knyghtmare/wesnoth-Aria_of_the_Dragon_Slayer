#. [teleport], id=sidhe
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:898
msgid ""
"This unit can access the Sidhe, or faerie plane, through every Great Tree, "
"thus being able to move as if teleporting through them. Inside a forest full "
"of Great Trees, this unit is virtually omnipresent."
msgstr ""
"Esta unidad puede acceder al Sidhe, o plano feérico, a través de cada Gran "
"Árbol, pudiendo así moverse como si se teletransportara a través de ellos. "
"Dentro de un bosque lleno de Grandes Árboles, esta unidad es virtualmente "
"omnipresente."

#. [teleport], id=sidhe
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:924
msgid ""
"This unit can access the Sidhe, or faerie plane, through every woodland, "
"thus being able to move from forest to forest as if teleporting. Inside "
"forested terrain, this unit is virtually omnipresent."
msgstr ""
"Esta unidad puede acceder al Sidhe, o plano feérico, a través de cada "
"bosque, pudiendo así moverse de bosque en bosque como si se "
"teletransportara. Dentro de terreno boscoso, esta unidad es virtualmente "
"omnipresente."

#. [heals], id=sylvan_soul
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:934
msgid "sylvan soul"
msgstr "alma silvana"

#. [heals], id=sylvan_soul
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:935
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:942
msgid ""
"This unit can heal and cure friendly units on adjacent hexes every turn, to "
"a maximum of 10 HP. In the woodlands, it will conceal itself from its "
"enemies, regenerate 8 HP per-turn and heal from poison."
msgstr ""
"Esta unidad puede curar y sanar unidades amigas en hexágonos adyacentes cada "
"turno, hasta un máximo de 10 PV. En terrenos boscosos, se ocultará de sus "
"enemigos, regenerará 8 PV por turno y se curará del veneno."

#. [regenerate], id=ability_perennial
