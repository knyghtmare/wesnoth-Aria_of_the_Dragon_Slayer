#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:803
msgid ""
"This unit's resistances are doubled, even above 50%, when defending. "
"Vulnerabilities are not affected."
msgstr ""
"Las resistencias de esta unidad se duplican, incluso por encima del 50 %, al "
"defender. Las vulnerabilidades no se ven afectadas."

#. [resistance], id=firearmour
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:816
msgid "fire armour"
msgstr "armadura de fuego"

#. [resistance], id=firearmour
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:817
msgid "female^fire armour"
msgstr "armadura de fuego"

#. [resistance], id=firearmour
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:818
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:821
msgid ""
"As this unit attacks, it becomes enveloped in a heat aura that hinders enemy "
"retaliation, doubling its resistances up to 50%. Vulnerabilities are not "
"affected."
msgstr ""
"Al atacar, esta unidad se envuelve en un aura de calor que dificulta la "
"retaliación enemiga, duplicando sus resistencias hasta un 50 %. Las "
"vulnerabilidades no se ven afectadas."

#. [leadership], id=uranometria
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:830
msgid "uranometria"
msgstr "uranometría"

#. [leadership], id=uranometria
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:831
