#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:839
msgid ""
"This unit channels the light of the moon and of the stars to ward of the "
"nocturnal darkness, thus strengthening itself in 25%."
msgstr ""
"Esta unidad canaliza la luz de la luna y de las estrellas para repeler la "
"oscuridad nocturna, fortaleciéndose así en un 25 %."

#. [teleport], id=skyvoyager
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:846
msgid "sky voyager"
msgstr "viajero del cielo"

#. [teleport], id=skyvoyager
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:847
msgid "female^sky voyager"
msgstr "viajera del cielo"

#. [teleport], id=skyvoyager
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:848
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:874
msgid ""
"This unit uses the magic currents in the air to move from one point to "
"another; to accomplish this, it must go to a mountain, and teleport to "
"another mountain."
msgstr ""
"Esta unidad usa las corrientes mágicas del aire para moverse de un punto a "
"otro; para lograrlo, debe ir a una montaña y teletransportarse a otra "
"montaña."

#. [regenerate], id=divine_immortality
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:883
msgid "divine essence"
msgstr "esencia divina"

#. [regenerate], id=divine_immortality
#: Aria_of_the_Dragon_Slayer/utils/aotds-abilities.cfg:884
