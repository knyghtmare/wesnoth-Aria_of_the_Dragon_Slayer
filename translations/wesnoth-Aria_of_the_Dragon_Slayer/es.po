#: Aria_of_the_Dragon_Slayer/scenarios/03_Haunted_By_The_Past.cfg:39
msgid "NOTE: Both Tenma and Olokun can recruit from 31,35 and 30,34"
msgstr "NOTA: Tanto Tenma como Olokun pueden reclutar desde 31,35 y 30,34"

