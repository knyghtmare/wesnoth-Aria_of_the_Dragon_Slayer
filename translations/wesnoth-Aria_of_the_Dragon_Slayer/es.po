#: Aria_of_the_Dragon_Slayer/scenarios/01_Dawn_Of_A_New_Day.cfg:184
#: Aria_of_the_Dragon_Slayer/scenarios/01_Dawn_Of_A_New_Day.cfg:802
#: Aria_of_the_Dragon_Slayer/scenarios/01_Dawn_Of_A_New_Day.cfg:1269
msgid "Miss Ohka"
msgstr "Señorita Ohka"

#. [unit], id=Midori, type=Yasai Peasant, gender=female
#. [unit], id=Midori, type=Sogen Huntress
